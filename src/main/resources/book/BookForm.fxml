<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="250.0" prefWidth="400.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/23.0.2" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.nptv23javafx.controller.MenuFormController">
    <children>
        <Label text="Добавление книги" />
        <TextField fx:id="titleField" promptText="Название книги" />
        <TextField fx:id="yearField" promptText="Год публикации" />
        <TextField fx:id="quantityField" promptText="Количество экземпляров" />
        <TextField fx:id="countField" promptText="В наличии" />
        <Button text="Сохранить" onAction="#showBookForm"/> <!-- Заглушка -->
        <Button text="Назад" onAction="#goBack"/>
    </children>
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
</VBox>
