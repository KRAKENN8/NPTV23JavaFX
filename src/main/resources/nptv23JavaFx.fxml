<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.nptv23javafx.Nptv23JavaFxController">
    <Label fx:id="label" prefHeight="50.0" prefWidth="604.0" text="Hello from FXML" />
   <HBox prefHeight="70.0" prefWidth="600.0">
      <children>
          <Button fx:id="button" onAction="#buttonClick" text="ClickMe" />
         <Button fx:id="button2" mnemonicParsing="false" text="И меня тоже нажми" onAction="#button2Click"/>
      </children>
   </HBox>
</VBox>
